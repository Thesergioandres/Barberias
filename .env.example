# ============================================================
# Variables de entorno para Docker Compose
# Copia este archivo como .env en la raíz del proyecto:
#   cp .env.example .env
# NUNCA subas el archivo .env al repositorio.
# ============================================================

# ── JWT ── ¡OBLIGATORIO CAMBIAR! ───────────────────────────
# Genera un secreto seguro con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REEMPLAZA_CON_UN_SECRETO_SEGURO_DE_64_BYTES
JWT_EXPIRES_IN=1d

# ── MongoDB ────────────────────────────────────────────────
MONGODB_URI=mongodb://mongo:27017/barberia
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=REEMPLAZA_CON_CONTRASENA_SEGURA

# ── Mongo Express (panel web de BBDD) ──────────────────────
# Usuario y contraseña para acceder al panel http://localhost:8081
ME_CONFIG_BASICAUTH_USERNAME=admin
ME_CONFIG_BASICAUTH_PASSWORD=REEMPLAZA_CON_CONTRASENA_PANEL

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── WhatsApp ───────────────────────────────────────────────
# Valores: mock | twilio | meta
WHATSAPP_PROVIDER=mock

# ── URLs ───────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost/api
CORS_ORIGINS=http://localhost
