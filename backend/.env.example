# ============================================================
# Backend - Variables de entorno
# Copia este archivo como .env y completa los valores.
#   cp .env.example .env
# NUNCA subas el archivo .env al repositorio.
# ============================================================

# ── Servidor ──────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
PORT=4000

# ── Base de datos ──────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/barberia
USE_MONGO=true

# ── Redis / Jobs ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Deshabilitar en desarrollo para no requerir Redis local
ENABLE_JOBS=false

# ── Red / Seguridad ────────────────────────────────────────
TRUST_PROXY=true
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=120
# Orígenes permitidos en CORS (separados por coma)
CORS_ORIGINS=http://localhost:5173

# ── WhatsApp ───────────────────────────────────────────────
# Valores: mock | twilio | meta
WHATSAPP_PROVIDER=mock

# ── JWT ── ¡OBLIGATORIO CAMBIAR EN PRODUCCIÓN! ─────────────
# Genera un secreto seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REEMPLAZA_CON_UN_SECRETO_SEGURO_DE_64_BYTES
JWT_EXPIRES_IN=1d

# ── Reglas de negocio (minutos) ────────────────────────────
MIN_ADVANCE_MINUTES=60
CANCEL_LIMIT_MINUTES=120
RESCHEDULE_LIMIT_MINUTES=120

# ── Horas silencio para notificaciones ────────────────────
QUIET_HOURS_START=22:00
QUIET_HOURS_END=07:00

# ── Cloudinary (opcional, para subida de imágenes) ─────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Web Push / VAPID (opcional, para notificaciones push) ──
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@tudominio.com
